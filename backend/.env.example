# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/app_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# OpenAI Configuration (fallback when ZHIPUAI_API_KEY is empty)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini

# ZhipuAI (GLM) Configuration — used when LLM_PROVIDER=zhipuai
ZHIPUAI_API_KEY=
ZHIPUAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZHIPUAI_EMBEDDING_MODEL=embedding-3
ZHIPUAI_CHAT_MODEL=GLM-4.7-Flash

# Google Gemini Configuration — default chat provider when GOOGLE_AI_API_KEY is set
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
GEMINI_CHAT_MODEL=gemini-2.1-flash

# LLM Provider override: "gemini" | "zhipuai" | "openai" (auto-detect if empty)
# When empty, auto-detects: gemini (if GOOGLE_AI_API_KEY set) > zhipuai > openai
# LLM_PROVIDER=gemini

# Embedding provider override: "google" | "voyage" | "zhipuai" | "openai" (auto-detect if empty)
# When empty, auto-detects: google (if GOOGLE_AI_API_KEY set) > voyage > zhipuai > openai.
# To force RAG embeddings through Voyage, set EMBEDDING_PROVIDER=voyage.
EMBEDDING_PROVIDER=voyage
# IMPORTANT: EMBEDDING_DIMENSION must match the DB pgvector column dimension.
# Latest migrations use vector(512) for Voyage. Re-ingest documents whenever
# changing embedding dimensions because existing vectors are invalidated.
EMBEDDING_DIMENSION=512
EMBEDDING_BATCH_SIZE=100
EMBEDDING_MAX_RETRIES=5
EMBEDDING_RETRY_BASE_SECONDS=2
EMBEDDING_RETRY_MAX_SECONDS=60

# Google embedding configuration (used when EMBEDDING_PROVIDER=google)
GOOGLE_EMBEDDING_MODEL=models/gemini-embedding-001

# Voyage AI Configuration (embeddings; used when EMBEDDING_PROVIDER=voyage)
VOYAGE_API_KEY=your-voyage-api-key-here
VOYAGE_BASE_URL=https://api.voyageai.com/v1/
VOYAGE_EMBEDDING_MODEL=voyage-4-lite

# RAG Configuration
CHUNK_MIN_TOKENS=500
CHUNK_MAX_TOKENS=800
CHUNK_OVERLAP_RATIO=0.2
TOP_K_RESULTS=10
SIMILARITY_THRESHOLD=0.7

# Document Processing
MAX_FILE_SIZE_MB=10
SUPPORTED_FILE_EXTENSIONS=pdf

# Rate Limiting
MAX_UPLOADS_PER_MINUTE=10
MAX_CHAT_QUERIES_PER_MINUTE=60

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google
